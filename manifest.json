{
  "manifest_version": 3,
  "name": "Twitch Rewind",
  "version": "1.0.0",
  "description": "Intercepts Twitch GQL responses for inspection and future modification.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.twitch.tv/*",
        "https://twitch.tv/*"
      ],
      "js": ["gql-hook.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
